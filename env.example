# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=your_bot_token_here

# ID канала (начинается с -100)
CHANNEL_ID=your_channel_id_here

# ID группы (начинается с -100)
GROUP_ID=your_group_id_here

# ID разрешенных групп (через запятую)
ALLOWED_GROUP_ID=your_group_id_here

# ID администраторов (через запятую)
ADMINS=admin_id1,admin_id2

# Imgur Client ID (для загрузки изображений)
IMGUR_CLIENT_ID=your_imgur_client_id

# Character AI Token (для AI-персонажа)
CHARACTER_AI_TOKEN=your_character_ai_token

# Character AI ID и Voice ID
CHARACTER_ID=your_character_id
CHARACTER_VOICE_ID=your_voice_id

# Hetzner Object Storage credentials for NASSAL2026 registrations
S3_ACCESS_KEY=your_object_storage_access_key
S3_SECRET_KEY=your_object_storage_secret_key
